# Gmail credentials for the contact form
# 1. Enable 2-Step Verification on your Google Account
# 2. Generate an App Password (Google Account -> Security -> App passwords)
# 3. Copy the 16-character password (no spaces) into GMAIL_APP_PASSWORD
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Comma-separated list of allowed origins for the /api/contact CORS check.
# Leave unset to allow only same-origin requests.
ALLOWED_ORIGINS=https://your-domain.com
